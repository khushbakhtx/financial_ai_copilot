# Financial AI Copilot — Environment Variables
# Copy this file to .env and fill in your actual values.

# ── LLM (Google Gemini) ────────────────────────────────────────────────────────
# Required: one of GOOGLE_API_KEY or GEMINI_API_KEY
GOOGLE_API_KEY="your_google_api_key_here"
# GEMINI_API_KEY="your_gemini_api_key_here"   # alias accepted by langchain-google-genai

# ── LangSmith tracing (optional but recommended) ──────────────────────────────
# LANGSMITH_API_KEY="your_langsmith_api_key_here"
# LANGSMITH_TRACING_V2=true
# LANGSMITH_PROJECT="financial-ai-copilot"
# LANGSMITH_TRACING_ENABLED=true   # set this to opt in; omit to disable tracing

# ── MongoDB Atlas (persistent memory + GridFS datasets + pipeline state) ───────
# Required for full functionality. Without it the agent uses local /tmp only.
MONGODB_URI="mongodb+srv://user:pass@cluster.mongodb.net/?retryWrites=true&w=majority"
MONGODB_DB="financial_ai_copilot"

# ── PostgreSQL (LangGraph checkpointer — thread state persistence) ─────────────
# Required for the backend to start.
DATABASE_URL="postgresql://user:pass@host:5432/dbname"

# ── E2B Sandbox (optional — falls back to local subprocess) ───────────────────
# Get a key at https://e2b.dev
# E2B_API_KEY="your_e2b_api_key_here"
# E2B_SANDBOX_TIMEOUT=1800   # seconds sandbox stays alive between calls (default 1800)

# ── Agent runtime ─────────────────────────────────────────────────────────────
# AGENT_WORKDIR="/tmp/financial_ai"          # local working dir for datasets/findings
# TERMINAL_SERVER_URL="http://localhost:8001" # where sandbox sends stdout/stderr
